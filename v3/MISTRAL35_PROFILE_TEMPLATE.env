# =====================================================================
#  rvllm profile TEMPLATE — Mistral Medium 3.5 NVFP4 (sm_121 / GB10)
#
#  STATUS: scaffolding only. The CUTLASS NVFP4 GEMM kernel
#  (kernels/cutlass_nvfp4_gemm_sm120.cu) is not yet implemented;
#  pointing rvllm-serve at this profile today succeeds through the
#  full validation chain (config + inventory + CUTLASS-symbol probe)
#  and then refuses every request with a typed "kernel not
#  implemented" error per `Mistral35Bringup`. Once the kernel lands
#  and `kernels/build_cutlass_sm120_so.sh` includes the NVFP4 source,
#  this profile activates without further changes — drop it into
#  ~/.rvllm/profiles/ and `sudo systemctl restart rvllm-serve`.
#
#  Required external state:
#   * Model directory in NVFP4-pack-quantized format
#     (e.g. zdy1995love/Mistral-Medium-3.5-128B-NVFP4) under a path
#     accessible to the rvllm-serve.service unit.
#   * libcutlass_sm120.so rebuilt with the NVFP4 entry points; the
#     loader checks every required symbol at startup and refuses the
#     bring-up if any one is missing.
#   * Mistral 3.5 chat template + tokenizer.json shipped alongside
#     config.json in the model dir.
# =====================================================================

# --- Mandatory paths (substitute for your install) ---
RVLLM_MODEL_DIR=/PATH/TO/mistral-medium-3.5-128b-nvfp4
RVLLM_MODEL_ID=mistral-medium-3.5
RVLLM_KERNELS_DIR=/home/r00t/workspace/upstream/rvllm-serve/kernels
RVLLM_CUTLASS_SM120_SO=/home/r00t/workspace/upstream/rvllm-serve/kernels/sm_121/libcutlass_sm120.so

# --- Family selection: explicit assertion, no auto-fallback ---
RVLLM_MODEL_FAMILY=mistral35

# --- Bind / queue / token caps ---
RVLLM_BIND=127.0.0.1:8010
RVLLM_QUEUE_DEPTH=4
# Mistral has a 262 144 token window via YaRN; in practice 32k–64k
# is plenty for chat. Keep the cap honest so admission catches
# oversize prompts before the worker.
RVLLM_MAX_TOKENS_CAP=8192
RVLLM_REQUEST_TIMEOUT_SECS=600

# --- Arena (HBM bump-allocator) ---
# 128B params at ~4.5 bits/element ≈ 72 GiB pure NVFP4 weight
# residency. Add ~8 GiB for KV (NVFP4 4 bits/elem × 8 KV heads ×
# 128 head_dim × 32k window × ~32 sequences worst-case), ~4 GiB
# for activations / scratch, ~2 GiB for vision-tower BF16 weights
# + projector. ~88 GiB total live set on a 128 GiB GB10 leaves
# enough headroom for CUTLASS workspaces and a Pixtral request
# in flight.
RVLLM_ARENA_GB=96

# --- KV cache: NVFP4 mandatory (per integration spec) ---
RVLLM_NVFP4_KV=1
RVLLM_F16_KV=0

# --- Mistral 3.5 batched-prefill phases (M-A through M-E) ---
# Match the Qwen production defaults so once the GPU forward path
# lands the same per-phase opt-out gates are available for bisect.
# See v3/MISTRAL35_BATCHED_PREFILL_PLAN.md for the per-gate kernel
# inventory.
RVLLM_MISTRAL35_BATCH_PROJ_PREFILL=1
RVLLM_MISTRAL35_BATCH_ROPE_PREFILL=1
RVLLM_MISTRAL35_BATCH_FULL_PREFILL=1
# Fused [Q || K || V] is opt-in — needs loader-side staging.
RVLLM_MISTRAL35_FUSED_QKV=0
# Decode-step CUDA Graph capture is parked (mirrors Qwen Phase 8).
RVLLM_MISTRAL35_DECODE_GRAPH=0

# --- Vision (Pixtral) admission caps ---
RVLLM_VISION_MAX_IMAGES=8
RVLLM_VISION_MAX_TOTAL_BYTES=67108864       # 64 MiB
# Pixtral max-edge 1540 → at most 55 × 55 = 3025 soft tokens per
# image. 8192 leaves room for ~2.7 max-resolution images per
# request; raise if your workload pushes that ceiling.
RVLLM_VISION_MAX_TOTAL_TOKENS=8192

# --- Prefill chunk size (matches the Gemma 4 NVFP4 profile) ---
RVLLM_PREFILL_CHUNK_SIZE=128
RVLLM_UNIFIED_PREFILL=1
RVLLM_BATCH_PREFILL=1
