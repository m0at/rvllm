# =====================================================================
#  rvllm profile TEMPLATE — Mistral Medium 3.5 NVFP4 (sm_121 / GB10)
#
#  STATUS (2026-05-10): production forward path is wired end-to-end.
#  Default is W4A16 fused GEMV (RVLLM_W4A16_GEMV=1, weights packed in
#  NVFP4 e2m1 + per-block e4m3 scales but activations stay BF16) with
#  a BF16 KV cache. Greedy-only sampling; non-greedy requests are
#  rejected at admission. Pixtral vision tower is loaded but image
#  splice into the decoder is NOT wired yet — vision-bearing requests
#  are rejected at admission. Drop into ~/.rvllm/profiles/ and
#  `sudo systemctl restart rvllm-serve`.
#
#  Required external state:
#   * Model directory in NVFP4-pack-quantized format
#     (e.g. zdy1995love/Mistral-Medium-3.5-128B-NVFP4) under a path
#     accessible to the rvllm-serve.service unit.
#   * libcutlass_sm120.so. Required for the legacy W4A16 fallback
#     path (RVLLM_W4A16_GEMV=0); the default fused GEMV path uses
#     stand-alone .cu kernels and does NOT touch CUTLASS.
#   * Mistral 3.5 chat template + tokenizer.json shipped alongside
#     config.json in the model dir.
# =====================================================================

# --- Mandatory paths (substitute for your install) ---
RVLLM_MODEL_DIR=/PATH/TO/mistral-medium-3.5-128b-nvfp4
RVLLM_MODEL_ID=mistral-medium-3.5
RVLLM_KERNELS_DIR=/home/r00t/workspace/upstream/rvllm-serve/kernels
RVLLM_CUTLASS_SM120_SO=/home/r00t/workspace/upstream/rvllm-serve/kernels/sm_121/libcutlass_sm120.so

# --- Family selection: explicit assertion, no auto-fallback ---
RVLLM_MODEL_FAMILY=mistral35

# --- Bind / queue / token caps ---
RVLLM_BIND=127.0.0.1:8010
RVLLM_QUEUE_DEPTH=4
# Mistral has a 262 144 token window via YaRN; in practice 32k–64k
# is plenty for chat. Keep the cap honest so admission catches
# oversize prompts before the worker.
RVLLM_MAX_TOKENS_CAP=8192
RVLLM_REQUEST_TIMEOUT_SECS=600

# --- Arena (HBM bump-allocator) ---
# 128B params at ~4.5 bits/element ≈ 72 GiB pure NVFP4 weight
# residency. Add the BF16 KV cache (~1.4 GiB at 4096 positions × 88
# layers × 8 KV heads × 128 head_dim, scaled with RVLLM_KV_CACHE_MAX_POS),
# ~4 GiB for activations / scratch, ~2 GiB for vision-tower BF16
# weights + projector. Total live set fits comfortably on a 128 GiB
# GB10.
RVLLM_ARENA_GB=96

# --- KV cache: BF16 (no NVFP4-KV path is wired today) ---
# Mistral 3.5 attention uses dedicated `mistral35_qk_dot_bf16` +
# `mistral35_softmax_v_bf16` kernels with a BF16 KV layout. Setting
# RVLLM_NVFP4_KV=1 has NO effect on Mistral; left here only for
# operators sharing this template across families.
RVLLM_NVFP4_KV=0
RVLLM_F16_KV=0
RVLLM_KV_CACHE_MAX_POS=4096

# --- W4A16 GEMV (production default) ---
# 1 = fused dequant→GEMV→BF16 in one kernel (default).
# 0 = legacy: dequantize weights to BF16 first, then bf16_gemm_f32.
#     Slower but kept as a parity oracle for the fused path; see
#     v3/tools/mistral35_w4a16_gemv_check.py.
RVLLM_W4A16_GEMV=1

# --- Mistral 3.5 prefill + decode batching (all default-on) ---
# These are the gates the executor actually reads. The previous
# RVLLM_MISTRAL35_BATCH_PROJ_PREFILL / BATCH_ROPE_PREFILL /
# BATCH_FULL_PREFILL / FUSED_QKV / DECODE_GRAPH names were planning
# placeholders that the executor never consumed — setting them
# logged a no-op warning at startup (load-time check in
# Mistral35Bringup::load). They have been removed from this
# template. The bring-up emits a deprecation warning if a stale
# profile still sets them.
#
# RVLLM_MISTRAL35_BATCH_PREFILL=1            chunked layer-major prefill
# RVLLM_MISTRAL35_CHUNK_BODY=1               use forward_chunk_body inside chunk
# RVLLM_MISTRAL35_PREFILL_CHUNK_SIZE=4096    M-rows per chunk (NOT
#                                            RVLLM_PREFILL_CHUNK_SIZE — that
#                                            one is Gemma 4 only)
# RVLLM_MISTRAL35_PREFILL_CHUNK_MIN=16       fall back to per-token below this
# RVLLM_MISTRAL35_BATCHED_ROPE=1             chunk-path batched RoPE
# RVLLM_MISTRAL35_BATCHED_KV_WRITE=1         chunk-path batched KV-write
# RVLLM_MISTRAL35_BATCHED_ATTN_PREFILL=1     batched split-kernel attention
# RVLLM_MISTRAL35_FA_DECODE=1                fused FA-2 decode (default-on)
# RVLLM_MISTRAL35_DECODE_FUSED_QKV=1         single-launch QKV decode GEMV
# RVLLM_MISTRAL35_DECODE_FUSED_GATE_UP=1     single-launch gate+up decode GEMV
# RVLLM_MISTRAL35_VISION_DEVICE_RESIDENT=1   slot-aware device splice
#
# Every flag listed is the production default; nothing needs to be
# set explicitly in a baseline profile. Keep the file lean — only
# set what you mean to override.

# --- Vision (Pixtral) admission caps ---
# Mistral 3.5 vision is wired end-to-end (Pixtral ViT + Patch
# Merger + device-resident splice). These caps bound the
# admission validator's per-request work.
RVLLM_VISION_MAX_IMAGES=8
RVLLM_VISION_MAX_TOTAL_BYTES=67108864       # 64 MiB
RVLLM_VISION_MAX_TOTAL_TOKENS=8192

# =====================================================================
#  Debug / diagnostic env (DO NOT set in production)
# =====================================================================
# RVLLM_DEBUG_NVFP4=1            — enables the NVFP4 debug knobs below.
#                                  Without this set, the loader rejects
#                                  any non-1.0 value of
#                                  RVLLM_NVFP4_ALPHA_MULT (F4#3 fail-
#                                  closed).
# RVLLM_NVFP4_ALPHA_MULT=<f32>   — multiplies every weight global-scale.
#                                  Diagnostic only; one warning is
#                                  logged at startup if non-1.0.
# RVLLM_SMOKE_SINGLE=1           — single-token diagnostic forward
#                                  (skips prefill loop entirely).
# RVLLM_SMOKE_DUMP_DIR=<dir>     — persists per-stage f32 vectors of
#                                  the last forward to <dir>.
# RVLLM_SMOKE_NO_RESTORE=1       — keeps every per-call scratch in the
#                                  arena (will OOM on long sequences).
# RVLLM_BOUNDARY_DUMP=1          — per-layer boundary tensor dumps.
# RVLLM_BOUNDARY_DUMP_LAYER=<i>  — restricts boundary dumps to one
#                                  layer index.
